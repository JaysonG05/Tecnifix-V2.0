# ─────────────────────────────────────────────
# Tecnifix v2.0 — Variables de entorno
# Copia este archivo como .env y rellena tus credenciales de Supabase
# Las encuentras en: supabase.com → tu proyecto → Settings → API
# ─────────────────────────────────────────────

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-public-key

# Web Push — clave PÚBLICA VAPID (la privada vive solo en el servidor).
# Genérala con:  npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=tu-vapid-public-key

# (Opcional) Observabilidad: endpoint que recibe los errores en JSON.
# Puede ser una Edge Function tuya, un webhook de Slack/Discord o un tunnel de
# Sentry. Si lo dejas vacío, los errores solo se ven en la consola (F12).
VITE_ERROR_WEBHOOK=
